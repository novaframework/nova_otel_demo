{erl_opts, [debug_info]}.
{src_dirs, [{"src", [{recursive, true}]}]}.
{shell, [{config, "./config/dev_sys.config"}, {apps, [nova_otel_demo]}]}.

{deps, [
    nova,
    {opentelemetry, "~> 1.5"},
    {opentelemetry_experimental, "~> 0.5"},
    {opentelemetry_exporter, "~> 1.8"},
    {opentelemetry_nova, {git, "https://github.com/novaframework/opentelemetry_nova.git", {branch, "main"}}}
]}.

{ct_compile_opts, [{i, "test/support"}]}.
{ct_first_files, ["test/support/test_metric_exporter.erl"]}.

{profiles, [
    {test, [
        {extra_src_dirs, ["test/support"]}
    ]}
]}.

{project_plugins, [
    {rebar3_nova, {git, "https://github.com/novaframework/rebar3_nova.git", {branch, "master"}}}
]}.

%% opentelemetry_nova's sed pre_hook uses a relative path that doesn't resolve
%% when rebar3 runs the hook from the dep directory, causing compile failure.
{overrides, [
    {override, opentelemetry_nova, [
        {pre_hooks, []}
    ]}
]}.
